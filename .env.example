OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
OPENROUTER_MODEL=openai/gpt-5-nano

# Maximum seconds to wait for a single LLM API call before raising a timeout error.
# Acceptable values: positive integer
LLM_TIMEOUT_SECONDS=60

# Maximum number of attempts for each LLM call before the error is surfaced.
# Retries only on transient errors (429, 500, 503). Non-retryable errors (401, 400)
# fail immediately regardless of this value.
# Acceptable values: positive integer
LLM_MAX_RETRIES=3

# ── LLM generation parameters ────────────────────────────────────────────────

# Maximum tokens the LLM may generate for the SQL response.
# Acceptable values: positive integer
SQL_MAX_TOKENS=10000

# Maximum tokens the LLM may generate for the answer response.
# Acceptable values: positive integer
ANSWER_MAX_TOKENS=220

# Maximum tokens the LLM may generate for the SQL analytics judge response.
# Acceptable values: positive integer
SQL_JUDGE_MAX_TOKENS=20000

# Maximum tokens the LLM may generate for the answer grounding judge response.
# Acceptable values: positive integer
ANSWER_JUDGE_MAX_TOKENS=20000

# Sampling temperature for SQL generation (0.0 = deterministic).
# Acceptable values: float in [0.0, 2.0]
SQL_TEMPERATURE=0.0

# Sampling temperature for answer generation. Slightly above 0 to vary phrasing.
# Acceptable values: float in [0.0, 2.0]
ANSWER_TEMPERATURE=0.2

# Sampling temperature for SQL analytics judge (0.0 = deterministic grading).
# Acceptable values: float in [0.0, 2.0]
SQL_JUDGE_TEMPERATURE=0.0

# Sampling temperature for answer grounding judge (0.0 = deterministic grading).
# Acceptable values: float in [0.0, 2.0]
ANSWER_JUDGE_TEMPERATURE=0.0

# Number of result rows included in the answer generation prompt body (capped).
# The full row count is always shown; only this many rows are serialised.
# Acceptable values: positive integer
ANSWER_ROWS_SAMPLE=30

# Reasoning effort per LLM stage. Controls how much internal computation the
# model invests. Only supported by reasoning-capable models; non-reasoning
# models ignore this parameter. Omit (or leave blank) to let the model decide.
# Acceptable values: xhigh | high | medium | low | minimal | none
# SQL_REASONING_EFFORT=
# ANSWER_REASONING_EFFORT=
# SQL_JUDGE_REASONING_EFFORT=
# ANSWER_JUDGE_REASONING_EFFORT=

# ── DB / execution ────────────────────────────────────────────────────────────

# Maximum rows fetched from SQLite per query. Queries returning more rows will
# set SQLExecutionOutput.rows_truncated=True.
# Acceptable values: positive integer
SQL_ROW_LIMIT=100

# Override the default paths only if your data files live elsewhere.
# DB_PATH=data/gaming_mental_health.sqlite
# METADATA_DB_PATH=data/schema_metadata.sqlite

# Name of the primary analytics table (must match the SQLite schema).
# TABLE_NAME=gaming_mental_health

# ── Schema ────────────────────────────────────────────────────────────────────

# Include human-readable column descriptions as inline comments in the DDL sent to the LLM.
# Disable to send a plain DDL with no annotations.
# Acceptable values: true, false
SCHEMA_INCLUDE_DESCRIPTION=true

# Collect post-execution result shape signals (empty_result, all_null_column:<col>, all_zero_column:<col>).
# These are informational monitoring flags — they never block the pipeline.
# Acceptable values: true, false
RESULT_VALIDATION_ENABLED=true

# After SQL validation passes, call the LLM to evaluate whether the SQL is analytically
# correct for the question (right aggregation, GROUP BY, granularity, filters).
# Verdict is appended to sql_generation.intermediate_outputs — non-blocking.
# Adds ~1 LLM call per request when enabled. Default off for production use.
# Acceptable values: true, false
SQL_ANALYTICS_JUDGE_ENABLED=false

# After answer generation, call the LLM to verify the answer is grounded in the
# result rows (no hallucinated values or unsupported conclusions).
# Verdict is appended to answer_generation.intermediate_outputs — non-blocking.
# Skipped automatically when sql is None or rows are empty.
# Adds ~1 LLM call per request when enabled. Default off for production use.
# Acceptable values: true, false
ANSWER_GROUNDING_JUDGE_ENABLED=false

# Re-generate the answer when the grounding judge flags it as ungrounded.
# Requires ANSWER_GROUNDING_JUDGE_ENABLED=true to produce a verdict to act on.
# The correction prompt includes the prior answer and the judge's issues so the
# LLM knows what specifically was wrong.
# Acceptable values: true, false
ANSWER_GROUNDING_JUDGE_CORRECTION_ENABLED=false

# Maximum correction attempts for answer grounding failures.
# Acceptable values: positive integer
MAX_ANSWER_GROUNDING_CORRECTION_RETRIES=3

# Unified SQL correction loop — re-generates SQL when any of the following
# signals indicate a problem. Each trigger has its own enable flag and retry cap.
# History of all prior (sql, reason) pairs is passed to the LLM on each attempt.
# Triggers fire in priority order: execution error → analytics judge → result validation.

# Re-generate SQL when the DB returns an execution error.
# Acceptable values: true, false
SQL_CORRECTION_ENABLED=false

# Maximum correction attempts for DB execution errors.
# Acceptable values: positive integer
MAX_SQL_CORRECTION_RETRIES=3

# Re-generate SQL when the analytics judge flags it as analytically incorrect.
# Requires SQL_ANALYTICS_JUDGE_ENABLED=true to produce a verdict to act on.
# Acceptable values: true, false
SQL_ANALYTICS_JUDGE_CORRECTION_ENABLED=false

# Maximum correction attempts for analytics judge failures.
# Acceptable values: positive integer
MAX_SQL_ANALYTICS_CORRECTION_RETRIES=3

# Re-generate SQL when result validation flags are set (e.g. empty_result).
# Requires RESULT_VALIDATION_ENABLED=true.
# Acceptable values: true, false
RESULT_VALIDATION_CORRECTION_ENABLED=false

# Maximum correction attempts for result validation failures.
# Acceptable values: positive integer
MAX_RESULT_VALIDATION_CORRECTION_RETRIES=3

# Log output level. Controls verbosity of structured JSON logs emitted to stderr.
# Acceptable values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log output format. "json" emits structured JSON (production). "pretty" emits
# human-readable console output (local dev).
# Acceptable values: json, pretty
LOG_FORMAT=json

# ── OpenTelemetry / Phoenix tracing ──────────────────────────────────────────

# Master switch for distributed tracing. When false (default), a NoOpTracerProvider
# is installed — all span decorators are zero-cost no-ops and no network connection
# to Phoenix is attempted.
# Acceptable values: true, false
OTLP_ENABLED=false

# HTTP OTLP endpoint for Phoenix OSS self-hosted.
# Phoenix listens on HTTP port 6006 by default (not gRPC port 4317).
# Only used when OTLP_ENABLED=true.
# PHOENIX_ENDPOINT=http://localhost:6006/v1/traces

# Project name shown in the Phoenix UI for grouping traces.
# Only used when OTLP_ENABLED=true.
# PHOENIX_PROJECT_NAME=analytics-pipeline

# Include the full SQL statement as db.statement on db.execute spans.
# Set to false if the database may contain PII — suppresses SQL text from traces
# while keeping all other span attributes (db.system, db.row_count, etc.).
# Acceptable values: true, false
OTLP_INCLUDE_SQL=true
